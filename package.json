{
  "name": "panda2",
  "version": "1.0.0",
  "description": "Panda2 with Client and Server in one Repo",
  "private": "true",
  "type": "module",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "dotenvx run -f .env -- tsx server/typescript/start.ts",
    "client": "webpack serve --config webpack.dev.js",

    "create_openapi_spec": "tsx create-openapi-spec.ts",
    "createtypes": "npm run create_openapi_spec && npx openapicmd typegen client/public/openapi.js > client/types/openapi.d.ts",
    "buildclient": "npm run createtypes && webpack --config webpack.prod.js",
    "buildserver": "rm -fR server/ecmascript && tsc",
    "starttestdb": "npm run stoptestdb ; docker run --name testdb -e POSTGRES_PASSWORD='blablubber' -p 8081:5432 -d --rm postgres:17.2-alpine3.20",
    "stoptestdb": "docker kill testdb",
    "ecmatest": "npx mocha --config mocha-ecmascript-rc.cjs",
    "tstest": "npx mocha --config mocha-typescript-rc.cjs",
    "test": "npm run starttestdb && npm run tstest && npm run stoptestdb",
    "purebuild": "npm run buildclient && npm run buildserver && npm run ecmatest",
    "build": "npm run starttestdb && npm run purebuild && npm run stoptestdb",
    "dockerbuild": "npm run starttestdb && docker buildx build -t erpbarczok:latest --network host . && npm run stoptestdb",
    "docker": "docker compose up"
  },
  "author": "Ralph Barczok",
  "license": "ISC",
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "debug": "^4.4.0",
    "express-openapi-validator": "^5.4.2",
    "morgan": "^1.10.0",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.5",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.3",
    "@babel/preset-typescript": "^7.26.0",
    "@dotenvx/dotenvx": "^1.33.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/debug": "^4.1.12",
    "@types/mocha": "^10.0.10",
    "@types/morgan": "^1.9.9",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.7",
    "axios": "^1.7.9",
    "babel-loader": "^9.2.1",
    "bootstrap": "^5.3.3",
    "concurrently": "^9.1.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "expect": "^29.7.0",
    "express": "^4.21.2",
    "globals": "^15.14.0",
    "html-webpack-plugin": "^5.6.3",
    "mocha": "^11.0.1",
    "openapi-client-axios": "^7.5.5",
    "react": "^19.0.0",
    "react-bootstrap": "^2.10.7",
    "react-bootstrap-icons": "^1.11.5",
    "react-dom": "^19.0.0",
    "style-loader": "^4.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0",
    "webpack-merge": "^6.0.1",
    "workbox-webpack-plugin": "^7.3.0"
  }
}
