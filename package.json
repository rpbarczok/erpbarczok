{
  "name": "erpbarczok",
  "version": "1.0.0",
  "description": "An ERP System with Client and Server in one Repo",
  "private": "true",
  "type": "module",
  "scripts": {
    "server": "dotenvx run -f .env -- tsx server/typescript/start.ts",
    "client": "webpack serve --config webpack.dev.js",
    
    "stop_dev_db": "docker kill devdb; sleep 2",
    "start_dev_db": "npm run stop_dev_db ; docker run --name devdb -e POSTGRES_PASSWORD='blablubber' -p 8082:5432 -d --rm postgres:17.2-alpine3.20",
    
    "start": "dotenvx run -f .env -- npm run create_types && npm run start_dev_db && concurrently \"npm run server\" \"npm run client\"",
    
    "create_openapi_spec": "tsx create-openapi-spec.ts",
    "create_types": "npm run create_openapi_spec && mkdir -p client/types && npx openapicmd typegen client/utils/openapi.json > client/types/openapi.d.ts",
    
    "build_client": "npm run create_types && webpack --config webpack.prod.js",
    "build_server": "rm -fR server/ecmascript && npx tsc --project server/typescript",
    
    "start_test_db": "npm run stop_test_db ; docker run --name testdb -e POSTGRES_PASSWORD='blablubber' -p 8081:5432 -d --rm postgres:17.2-alpine3.20",
    "stop_test_db": "docker kill testdb",
    
    "ecma_test": "cd server && npx mocha --config mocha-ecmascript-rc.cjs --exit",
    "ts_test": "cd server && npx mocha  --config mocha-typescript-rc.cjs --exit",
    "test_e2e": "cd client && npx mocha ./puppeteer/**/*.e2e.test.ts --exit",
    "posttest_e2e": "npm run start_test_db",
    "test_frontend": "cd client && npx mocha --config ./mocha-typescript-rc.cjs './**/*.test.{ts,tsx}'",
    "test_backend": "npm run ts_test",
    "test": "npm run ts_test && npm run test_frontend ",
    
    "lint": "eslint .",
    
    "pure_build": "npm run build_client && npm run build_server && npm run ecma_test",
    "build": "npm run start_test_db && npm run pure_build && npm run stop_test_db",
    "docker_build": "npm run start_test_db && docker buildx build --load -t erpbarczok:latest --network host . && npm run stop_test_db",
    "docker": "docker compose up"
  },
  "author": "Ralph Barczok",
  "license": "MIT",
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "debug": "^4.4.0",
    "express-jwt": "^8.5.1",
    "express-openapi-validator": "^5.4.2",
    "jsesc": "^3.1.0",
    "jwks-rsa": "^3.1.0",
    "morgan": "^1.10.0",
    "oidc-client-ts": "^3.1.0",
    "pg": "^8.13.1",
    "pg-hstore": "^2.3.4",
    "proxy-agent": "^6.5.0",
    "react-oidc-context": "^3.2.0",
    "sequelize": "^6.37.5",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.3",
    "@babel/preset-typescript": "^7.26.0",
    "@dotenvx/dotenvx": "^1.33.0",
    "@eslint/js": "^9.23.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/debug": "^4.1.12",
    "@types/jsdom": "^21.1.7",
    "@types/jsesc": "^3.0.3",
    "@types/mocha": "^10.0.10",
    "@types/morgan": "^1.9.9",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/sinon": "^17.0.4",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.7",
    "axios": "^1.7.9",
    "babel-loader": "^9.2.1",
    "bootstrap": "^5.3.3",
    "concurrently": "^9.1.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.2",
    "eslint": "^9.23.0",
    "eslint-plugin-mocha": "^10.5.0",
    "eslint-plugin-react": "^7.37.4",
    "expect": "^29.7.0",
    "express": "^4.21.2",
    "file-loader": "^6.2.0",
    "global-jsdom": "^26.0.0",
    "globals": "^16.0.0",
    "html-webpack-plugin": "^5.6.3",
    "ignore-styles": "^5.0.1",
    "jsdom": "^26.0.0",
    "mocha": "^11.0.1",
    "openapi-client-axios": "^7.5.5",
    "pptr-testing-library": "^0.8.0",
    "puppeteer": "^24.7.0",
    "react": "^19.0.0",
    "react-bootstrap": "^2.10.7",
    "react-bootstrap-icons": "^1.11.5",
